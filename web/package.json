{
  "name": "coding-plan-comparison-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "fetch-plans": "tsx scripts/fetch-plans/fetch-plans.ts",
    "fetch-plans:test": "tsx --test 'scripts/fetch-plans/lib/*.test.ts' 'scripts/fetch-plans/scrapers/*.test.ts'",
    "fetch-plans:typecheck": "tsc --noEmit -p scripts/fetch-plans"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "cheerio": "^1.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  },
  "dependencies": {
    "echarts": "^5.5.0"
  }
}
