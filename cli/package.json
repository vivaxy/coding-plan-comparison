    "cli"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.12.0",
    "semantic-release": "^25.0.3",
    "semantic-release-monorepo": "^8.0.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0"
  }
